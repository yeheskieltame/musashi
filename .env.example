# 0G Chain — Mainnet (Chain ID: 16661)
OG_CHAIN_RPC=https://evmrpc.0g.ai
OG_CHAIN_PRIVATE_KEY=           # OPTIONAL — only for on-chain publishing (hex, with or without 0x prefix). Use a dedicated wallet.

# Deployed contracts on 0G Mainnet (Chain ID: 16661).
# ConvictionLog stores STRIKE log + reputation. MusashiINFT is the ERC-7857
# Intelligent NFT holding agent identity, with encrypted intelligence bundles
# stored on 0G Storage and an ECIES-sealed AES key per owner. Both addresses
# are verified on https://chainscan.0g.ai — override via the env vars below
# if you redeploy.
CONVICTION_LOG_ADDRESS=0x2B84aC25498FF0157fAB04fEa9e3544A14882A15
MUSASHI_INFT_ADDRESS=0x74BC82d4A348d661ffF344A4C21c4C04F47C1d4c

# Optional: override explorer URLs
# OG_EXPLORER_URL=https://chainscan.0g.ai
# OG_STORAGE_SCAN_URL=https://storagescan.0g.ai

# 0G Storage — Mainnet
# Uses official 0g-storage-client CLI for file upload
OG_STORAGE_RPC=https://evmrpc.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-turbo.0g.ai
