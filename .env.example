# 0G Chain — Galileo Testnet (Chain ID: 16602)
OG_CHAIN_RPC=https://evmrpc-testnet.0g.ai
OG_CHAIN_PRIVATE_KEY=           # deployer wallet private key (hex, with or without 0x prefix)

# Deployed contract addresses (set after `make deploy`)
CONVICTION_LOG_ADDRESS=        # e.g. 0x7698c369Cec5bFD14bFe9184ea19D644540f483b
MUSASHI_INFT_ADDRESS=          # e.g. 0xFB1Cd4b556eCA02D84BA3754Fbd4Fe2C81aEE488

# Optional: override explorer URLs for mainnet
# OG_EXPLORER_URL=https://chainscan-galileo.0g.ai
# OG_STORAGE_SCAN_URL=https://storagescan-galileo.0g.ai

# 0G Storage — Galileo Testnet (Turbo)
# Uses official 0g-storage-client CLI for file upload
OG_STORAGE_RPC=https://evmrpc-testnet.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai 